
# Server Configuration
PORT=5000

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=artnft_db

# JWT Configuration
JWT_SECRET=your_very_strong_jwt_secret
JWT_EXPIRES_IN=1d # e.g., 1 day, 7d, 2h

# Optional: API Keys for external services (if any)
# SOME_EXTERNAL_API_KEY=your_api_key
