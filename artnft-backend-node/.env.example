
# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration (PostgreSQL - Example for Supabase)
# Replace with your actual Supabase connection details
DB_DIALECT=postgres
DB_HOST=db.lyikgkveynfetfadsjix.supabase.co
DB_USER=postgres
DB_PASSWORD=YOUR_ACTUAL_SUPABASE_DATABASE_PASSWORD # IMPORTANT: Replace with your Supabase DB password
DB_NAME=postgres
DB_PORT=5432

# Optional: PostgreSQL SSL (uncomment and set to true if your provider requires it and it's not default)
# DB_SSL=false

# Database Pool Configuration (Optional - sensible defaults are in environment.ts)
# DB_POOL_MAX=5
# DB_POOL_MIN=0
# DB_POOL_ACQUIRE=30000
# DB_POOL_IDLE=10000

# JWT Configuration
JWT_SECRET=YOUR_VERY_STRONG_AND_RANDOM_JWT_SECRET_KEY_HERE_FOR_BACKEND_TS
JWT_EXPIRES_IN=1d
